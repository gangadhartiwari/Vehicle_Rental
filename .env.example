# App
APP_NAME=VehicleRentalAPI
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database — use SQLite for dev, Postgres for prod
DATABASE_URL=sqlite:///./vehicle_rental.db
# DATABASE_URL=postgresql://user:password@localhost:5432/vehicle_rental

# Security
SECRET_KEY=change-this-to-a-long-random-string-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# OTP
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=30

# Twilio (optional — leave blank to use console-mock OTP in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis (optional — falls back to in-memory if not provided)
REDIS_URL=

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Pricing defaults (INR)
DEFAULT_BIKE_HOURLY_RATE=40
DEFAULT_CAR_HOURLY_RATE=150
DEFAULT_AUTO_HOURLY_RATE=80
DEFAULT_SECURITY_DEPOSIT=2000
GST_PERCENT=18

# Maps (optional)
GOOGLE_MAPS_API_KEY=

# Admin bootstrap
ADMIN_EMAIL=admin@vehiclerental.com
ADMIN_PASSWORD=Admin@12345

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
